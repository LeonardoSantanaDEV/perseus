# URL base do Perseus (Socket.IO + REST)
PERSEUS_WS=http://localhost:3000
PERSEUS_API=http://localhost:3000/api

# Token do runner (gerado no portal em "Runners")
RUNNER_TOKEN=cole-o-token-do-runner-aqui

# Intervalo de heartbeat (segundos)
HEARTBEAT_INTERVAL=10

# Diretório de trabalho onde os pacotes são extraídos e executados
WORK_DIR=_work

# Manter o diretório de trabalho após a tarefa (apenas para depuração).
# Em produção/24-7 deixe "false" para não encher o disco.
KEEP_WORK_DIR=false

# Executável Python usado para criar os ambientes virtuais dos bots
PYTHON_BIN=python

# Caminho para o SDK do Perseus (instalado automaticamente no venv de cada bot).
# Aponte para a pasta packages/sdk-python do monorepo (caminho absoluto recomendado).
SDK_PATH=../../packages/sdk-python
