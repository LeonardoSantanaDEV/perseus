# Banco de dados (Postgres via docker-compose)
DATABASE_URL="postgresql://perseus:perseus@localhost:5432/perseus?schema=public"

# Servidor
PORT=3000
# Origem do front para CORS
WEB_ORIGIN=http://localhost:5173

# JWT
JWT_SECRET=troque-este-segredo-em-producao
JWT_EXPIRES_IN=7d
# Tempo de vida do token de tarefa (usado pelo SDK do bot)
TASK_TOKEN_EXPIRES_IN=12h

# Usuário admin criado no seed
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=admin123

# Storage S3/MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_PACKAGES=perseus-packages
S3_BUCKET_ARTIFACTS=perseus-artifacts
S3_FORCE_PATH_STYLE=true
# URL pública base usada para montar links de download (signed)
S3_PUBLIC_ENDPOINT=http://localhost:9000

# Segundos sem heartbeat para considerar um runner OFFLINE
RUNNER_OFFLINE_AFTER_SECONDS=30
