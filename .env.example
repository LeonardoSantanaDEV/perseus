# ============================================================
# Perseus — configuração da stack Docker (raiz)
#
# Copie para .env e ajuste o necessário:
#   cp .env.example .env        (Linux/Mac)
#   copy .env.example .env      (Windows)
#
# Tudo tem default de desenvolvimento; em PRODUÇÃO troque os
# segredos marcados com (!) — a API recusa subir com valores
# padrão quando NODE_ENV=production.
# ============================================================

# Ambiente: "development" ou "production"
NODE_ENV=development

# ---- Portas publicadas no host ----
WEB_PORT=8080
API_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---- Banco de dados ----
POSTGRES_USER=perseus
POSTGRES_PASSWORD=perseus
POSTGRES_DB=perseus

# ---- Segurança / JWT ----
# (!) Em produção use >= 32 caracteres aleatórios.
# Ex: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=dev-secret-troque-em-producao
JWT_EXPIRES_IN=7d
TASK_TOKEN_EXPIRES_IN=12h
LOGIN_THROTTLE_WINDOW_MS=60000
LOGIN_THROTTLE_MAX=10
TASK_MAX_RUNTIME_SECONDS=3600

# ---- Usuário admin criado no seed ----
ADMIN_EMAIL=admin@local
# (!) Troque em produção.
ADMIN_PASSWORD=admin123

# ---- Storage S3 / MinIO ----
# (!) Troque as credenciais em produção.
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET_PACKAGES=perseus-packages
S3_BUCKET_ARTIFACTS=perseus-artifacts
# Endpoint público (host) usado para montar links de download assinados.
# É o que o runner/navegador acessam. Em produção, troque para o host/domínio real.
S3_PUBLIC_ENDPOINT=http://localhost:9000

# Tempo sem heartbeat para marcar um runner como OFFLINE
RUNNER_OFFLINE_AFTER_SECONDS=30

# ---- CORS / URLs do front-end ----
# WEB_ORIGIN deve bater com o endereço onde o navegador carrega o Web.
WEB_ORIGIN=http://localhost:8080
# VITE_* são embutidas no bundle em build-time (acesso a partir do navegador).
VITE_API_URL=http://localhost:3000/api
VITE_WS_URL=http://localhost:3000
